<Window x:Class="Presentation_Layer__WPF_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Presentation_Layer__WPF_"
        mc:Ignorable="d"
        Title="Home" Height="600" Width="1000"
        WindowState="Minimized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="6*"/>
        </Grid.RowDefinitions>


        <DockPanel Grid.Row="0"
               x:Name="Panal1"
               Background="Blue"/>

        <Button Grid.Row="0" x:Name="btnAdd"  Background="LavenderBlush" Panel.ZIndex="1" Width="200" Height="100" Margin="0,0,50,0"
                HorizontalAlignment="Right" Content="Add New Contact" FontStyle="Italic"
                FontSize="20" FontWeight="Bold" Click="btnAdd_Click" />
        <DataGrid Grid.Row="1"
              x:Name="DG"
              d:ItemsSource="{d:SampleData ItemCount=5}"
              AlternationCount="1000000"
              FontFamily="Arial Black"
              IsReadOnly="True" Loaded="DG_Loaded"
              LoadingRow="DG_LoadingRow">

            


            <DataGrid.ContextMenu >
                <ContextMenu >
                    <MenuItem Header="Edit" Click="EditMenuItem_Click" />
                    <MenuItem Header="Delete" Click="DeleteMenuItem_Click" />
                </ContextMenu>
            </DataGrid.ContextMenu>

        </DataGrid>
    </Grid>

</Window>
