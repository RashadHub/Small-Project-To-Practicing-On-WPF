<Window x:Class="Presentation_Layer__WPF_.AddEditForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add / Edit Contact"
        Height="700" Width="950"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        MinWidth="800" MinHeight="600"
        Background="#F0F2F5">

    <Window.Resources>
        <!-- Modern button style - Simplified without converter -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3498DB"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DatePicker style -->
        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ComboBox style -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        
            <TextBlock x:Name="txtblcMode" Text="✏️ Add New Contact"
            FontSize="32"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="#2C3E50"
                   Margin="0,0,0,20">
            <TextBlock.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.2"/>
            </TextBlock.Effect>
            </TextBlock>
        

        <!-- Main Content: Form + Image -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Form Fields -->
            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Contact ID (read-only) -->
                <Border Grid.Row="0" Margin="0,5" Padding="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock  Text="Contact ID:" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="txtblcContactID" Text="___" Foreground="#7F8C8D" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- First Name -->
                <Border Grid.Row="1" Margin="0,5" Padding="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="First Name:" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtFirstName" Grid.Column="1" ToolTip="Enter first name"/>
                    </Grid>
                </Border>

                <!-- Last Name -->
                <Border Grid.Row="2" Margin="0,5" Padding="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Last Name:" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtLastName" Grid.Column="1" ToolTip="Enter last name"/>
                    </Grid>
                </Border>

                <!-- Email -->
                <Border Grid.Row="3" Margin="0,5" Padding="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Email:" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtEmail" Grid.Column="1" ToolTip="example@domain.com"/>
                    </Grid>
                </Border>

                <!-- Phone -->
                <Border Grid.Row="4" Margin="0,5" Padding="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Phone:" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtPhone" Grid.Column="1" ToolTip="+1234567890"/>
                    </Grid>
                </Border>

                <!-- Date of Birth -->
                <Border Grid.Row="5" Margin="0,5" Padding="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="txtblcDataOfBirth" Text="Date of Birth:" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        <DatePicker x:Name="dpBirthDate" Grid.Column="1"/>
                    </Grid>
                </Border>

                <!-- Country -->
                <Border Grid.Row="6" Margin="0,5" Padding="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Country:" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        <ComboBox x:Name="cboCountry" Grid.Column="1" ToolTip="Select country"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right: Image Section -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="Profile Picture" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                    <Button x:Name="SetImageButton" Content="📁 Set Image" Click="SetImageButton_Click" Width="100" Background="#3498DB"/>
                    <Button x:Name="RemoveImageButton" Content="🗑️ Remove" Click="RemoveImageButton_Click" Width="100" Background="#E74C3C"/>
                </StackPanel>

                <Border BorderBrush="#BDC3C7" BorderThickness="2" CornerRadius="12"
                        Height="220" Background="White" Margin="0,5,0,15">
                    <Grid>
                        <Image x:Name="imgPreview" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock x:Name="tbNoImage" Text="🖼️ No Image Selected"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#95A5A6" FontSize="14" FontWeight="SemiBold"
                                   Visibility="Visible"/>
                    </Grid>
                </Border>
                <TextBlock Text="Supports: JPG, PNG, BMP, GIF" FontSize="11" Foreground="#7F8C8D" TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Bottom: Address + Action Buttons -->
        <StackPanel Grid.Row="2" Margin="0,25,0,0">
            <TextBlock Text="📍 Address" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#2C3E50"/>
            <TextBox x:Name="txtAddress" Height="70" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" ToolTip="Full address"
                     BorderBrush="#BDC3C7" BorderThickness="1" Padding="8,4"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="CloseButton" Content="Close" Width="120" Click="CloseButton_Click" Background="#95A5A6"/>
                <Button x:Name="SaveButton" Content="💾 Save" Width="120" Click="SaveButton_Click" Background="#27AE60"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>